# stock-trader web — local
ENV=local
NEXT_PUBLIC_API_BASE=http://localhost:3002
NEXT_PUBLIC_BFF_URL=/bff
NEXT_PUBLIC_RISK_ENGINE_URL=/bff

# ── Auth JWT 서명 시크릿 (Next.js Route Handlers) ────────────────────────────────
