# stock-trader — local (직접실행, sqlite, 외부의존 최소)
APP_ENV=local

# DB (local = sqlite, compose 없이 직접실행)
DATABASE_URL=sqlite:///./local.db
REDIS_URL=

# Rust risk-engine
ENV=local
RISK_ENGINE_PORT=3001

# Web (브라우저 접근 URL)
NEXT_PUBLIC_BFF_URL=/bff
NEXT_PUBLIC_RISK_ENGINE_URL=/bff

# 서비스 URL (agents → 각 서비스 호출)
ANALYSIS_URL=http://localhost:8001
RAG_URL=http://localhost:8002
INGEST_URL=http://localhost:8003
RISK_ENGINE_URL=http://localhost:3001

# ⚠️  증권사 API — OS Keychain 또는 Vault 로컬 사용. 이 파일에 실 키 기재 금지.
# BROKER_API_KEY=
# BROKER_API_SECRET=
# BROKER_WS_URL=

# LLM API — OS Keychain 또는 Vault 로컬 사용. 이 파일에 실 키 기재 금지.
# ANTHROPIC_API_KEY=

# ── Auth JWT 서명 시크릿 (web/apps/dashboard Next.js Route Handlers) ────────────
# ⚠️  실 키 이 파일 기재 금지 — OS Keychain 또는 Vault 주입
# 발급 방법:
#   macOS Keychain:  security add-generic-password -a stock-trader -s AUTH_JWT_SECRET -w "$(openssl rand -base64 32)"
#                    security find-generic-password -a stock-trader -s AUTH_JWT_SECRET -w
#   CLI 생성:        openssl rand -base64 32
#                    node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_JWT_SECRET=fhwcbbpqxvJnIKXdHgPDenktIGzXyHbtQAJltv1wODc=
