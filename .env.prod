# stock-trader — prod (K8s + Helm + Argo CD)
# ⚠️  실 시크릿 절대 기재 금지 — HashiCorp Vault / K8s External Secrets 사용
APP_ENV=prod

# DB — Docker Compose 내부 라우팅 (K8s: Vault 주입으로 덮어씀)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=stock_trader
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/stock_trader
DATABASE_URL_SYNC=postgresql://app:app@postgres:5432/stock_trader
REDIS_URL=redis://redis:6379/0

ENV=prod
RISK_ENGINE_PORT=3001

# 브라우저 접근 URL (Docker Compose 기준 localhost — K8s: 도메인으로 덮어씀)
NEXT_PUBLIC_BFF_URL=http://localhost:3002
NEXT_PUBLIC_RISK_ENGINE_URL=http://localhost:3001

# 서비스 내부 URL — Docker Compose 서비스명
ANALYSIS_URL=http://analysis:8001
RAG_URL=http://rag:8002
INGEST_URL=http://ingest:8003
AGENTS_URL=http://agents:8004
RISK_ENGINE_URL=http://risk-engine:3001
BFF_URL=http://bff:3002

# 모든 시크릿: K8s Secret → External Secrets Operator → Vault
# BROKER_API_KEY, BROKER_API_SECRET, ANTHROPIC_API_KEY, AUTH_JWT_SECRET 등
AUTH_JWT_SECRET=${AUTH_JWT_SECRET}
