# stock-trader — 환경 변수 예시 (커밋용 템플릿, 실 값 절대 기재 금지)
# 사용법: cp .env.example .env.local  →  실 값 채우기
APP_ENV=local

# ── DB ───────────────────────────────────────────────────────────────────────────
# local
DATABASE_URL=sqlite:///./local.db
# dev+
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/stock_trader
POSTGRES_USER=app
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=stock_trader

# ── Redis (멱등키 · 인메모리 큐) ────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Rust risk-engine ─────────────────────────────────────────────────────────────
ENV=local
RISK_ENGINE_PORT=3001

# ── Web ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:3002
NEXT_PUBLIC_RISK_ENGINE_URL=http://localhost:3001

# ── 서비스 내부 URL ───────────────────────────────────────────────────────────────
ANALYSIS_URL=http://localhost:8001
RAG_URL=http://localhost:8002
INGEST_URL=http://localhost:8003
RISK_ENGINE_URL=http://localhost:3001

# ── 증권사 API (OS Keychain 또는 Vault — 이 파일에 실 키 절대 기재 금지) ──────────
BROKER_API_KEY=<vault-or-keychain>
BROKER_API_SECRET=<vault-or-keychain>
BROKER_WS_URL=wss://<broker-host>/ws

# ── LLM API (OS Keychain 또는 Vault — 이 파일에 실 키 절대 기재 금지) ────────────
ANTHROPIC_API_KEY=<vault-or-keychain>

# ── Auth JWT 서명 시크릿 (web/apps/dashboard — Next.js Route Handlers) ───────────
# ⚠️  이 파일에 실 키 절대 기재 금지 — OS Keychain 또는 Vault 주입
# 발급 방법:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# macOS Keychain 저장:
#   security add-generic-password -a stock-trader -s AUTH_JWT_SECRET -w "$(openssl rand -base64 32)"
# Keychain 읽기:
#   security find-generic-password -a stock-trader -s AUTH_JWT_SECRET -w
AUTH_JWT_SECRET=<vault-or-keychain>
